<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:id="@+id/tvBienvenida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bienvenido"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:padding="16dp"
        android:layout_marginBottom="30dp">

        <TextView
            android:id="@+id/tvHorasExtra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Horas Extra: Calculando..."
            android:textAlignment="center"
            android:textColor="#333333"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btnEntrada"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="REGISTRAR ENTRADA"
        android:textSize="18sp"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnSalida"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="REGISTRAR SALIDA"
        android:textSize="18sp"
        android:backgroundTint="#F44336"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnIncidencias"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="REPORTAR INCIDENCIA"
        android:backgroundTint="#FF9800"
        android:layout_marginBottom="30dp" />

    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estado: Esperando acción o NFC..."
        android:textAlignment="center"
        android:textColor="#757575"/>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cerrar Sesión"
        android:layout_marginTop="30dp"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>

</LinearLayout>